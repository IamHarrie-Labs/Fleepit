{
  "crons": [
    {
      "path": "/api/alert-cron",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/alert-cron",
      "schedule": "0 20 * * *"
    }
  ],
  "rewrites": [
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/((?!api/|docs\\.html|docs$).*)", "destination": "/index.html" }
  ]
}

# Copy this file to .env and fill in your real values.
# .env is gitignored — this file is safe to commit.

VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign

# Vercel cron — background Telegram alerts (twice daily)
TELEGRAM_CHAT_ID=your_telegram_chat_id
CRON_SECRET=any_random_secret_string

# Upstash Redis — subscriber storage (free at console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Etherscan API key (free at etherscan.io/apis) — powers wallet token holdings
# and transaction history via the Etherscan V2 API on Mantle (chainid 5000).
# Server-side only, never exposed to the browser. Gas + native balance work
# without it (they use the public Mantle RPC).
ETHERSCAN_API_KEY=your_etherscan_api_key

# On-chain agent identity (ERC-8004 Identity Registry) — set after running
# scripts/identity-registry/deploy.mjs. Leave unset and the "Agent Identity"
# badge on the Landing page simply doesn't render; nothing fakes an identity.
VITE_IDENTITY_REGISTRY_ADDRESS=
VITE_AGENT_TOKEN_ID=0
VITE_AGENT_CHAIN_ID=5003
IDENTITY_REGISTRY_ADDRESS=
AGENT_ONCHAIN_ADDRESS=
MANTLE_CHAIN_ID=5003
